#!/usr/bin/env bash
#
# expctl — drive the running experiment build over adb.
#
# Setup (once per device session):  ./expctl forward
# Usage:                            ./expctl <command> [args...]
#
# Examples:
#   ./Tools/expctl ping
#   ./Tools/expctl scenes
#   ./Tools/expctl load RevisedPlaceRotateScale
#   ./Tools/expctl reload
#   ./Tools/expctl clear
#   ./Tools/expctl screenshot
#   ./Tools/expctl help
#
set -u

PORT="${EXPCTL_PORT:-9999}"

send() {
  curl -s "http://localhost:$PORT/" -d "$*"
}

case "${1:-}" in
  forward)
    adb forward "tcp:$PORT" "tcp:$PORT"
    echo "forwarded localhost:$PORT -> device:$PORT"
    ;;

  screenshot)
    reply="$(send screenshot "${2:-}")"
    echo "$reply"
    if [[ "$reply" == saved\ * ]]; then
      devpath="${reply#saved }"
      adb pull "$devpath" ./ && echo "pulled $(basename "$devpath")"
    fi
    ;;

  "")
    echo "usage: expctl <command> [args...]   (try: expctl help)" >&2
    exit 1
    ;;

  *)
    send "$@"
    ;;
esac
